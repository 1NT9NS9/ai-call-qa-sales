{
  "version": 1,
  "agents": {
    "test-agent": {
      "writable_paths": [
        "apps/app-api/tests",
        "data/demo"
      ]
    },
    "code-agent": {
      "writable_paths": [
        "apps/app-api/src",
        "apps/app-api/alembic",
